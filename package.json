{
  "name": "claude-plugins-manager",
  "displayName": "Claude Plugins Manager",
  "description": "Manage Claude Code Marketplace, Plugin, and MCP Server",
  "version": "0.1.5",
  "publisher": "lova",
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivalalova/claude-plugins-manager"
  },
  "keywords": [
    "claude",
    "claude-code",
    "plugin",
    "marketplace",
    "mcp"
  ],
  "engines": {
    "vscode": "^1.85.0",
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "main": "./dist/extension/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-plugins-manager",
          "title": "Claude Plugins Manager",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "claude-plugins-manager": [
        {
          "type": "webview",
          "id": "claude-plugins-manager.sidebarView",
          "name": "Claude Plugins Manager"
        }
      ]
    },
    "commands": [
      {
        "command": "claude-plugins-manager.openMarketplace",
        "title": "Open Marketplace Manager",
        "category": "Claude Code"
      },
      {
        "command": "claude-plugins-manager.openPlugin",
        "title": "Open Plugin Manager",
        "category": "Claude Code"
      },
      {
        "command": "claude-plugins-manager.openMcp",
        "title": "Open MCP Server Manager",
        "category": "Claude Code"
      },
      {
        "command": "claude-plugins-manager.openSkill",
        "title": "Open Skills Manager",
        "category": "Claude Code"
      },
      {
        "command": "claude-plugins-manager.openSettings",
        "title": "Open Settings Manager",
        "category": "Claude Code"
      },
      {
        "command": "claude-plugins-manager.openInfo",
        "title": "Open Extension Info",
        "category": "Claude Code"
      }
    ]
  },
  "scripts": {
    "build:extension": "node esbuild.extension.mjs",
    "build:webview": "node esbuild.webview.mjs",
    "build": "npm run build:extension && npm run build:webview",
    "watch:extension": "node esbuild.extension.mjs --watch",
    "watch:webview": "node esbuild.webview.mjs --watch",
    "watch": "concurrently \"npm:watch:extension\" \"npm:watch:webview\"",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ scripts/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json",
    "check:schema": "npx tsx scripts/check-settings-schema.ts",
    "verify": "npm run typecheck && npm run lint && npm run check:schema && npm test && npm run build",
    "package": "npm run build && vsce package --no-dependencies --no-rewrite-relative-links",
    "install:ext": "pnpm install && npm run package && code --install-extension claude-plugins-manager-$npm_package_version.vsix --force",
    "uninstall:ext": "code --uninstall-extension lova.claude-plugins-manager",
    "version:bump": "bash scripts/version.sh",
    "publish": "npx vsce publish --no-dependencies",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.39.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^28.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "marked": "^17.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
